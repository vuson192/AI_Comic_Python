# Ollama (story generation)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=CognitiveComputations/dolphin-llama3.1:8b

# ComfyUI (image generation)
COMFYUI_BASE_URL=http://localhost:8188
COMFYUI_OUTPUT_DIR=./output

# Image generation defaults
IMAGE_WIDTH=1024
IMAGE_HEIGHT=1024
IMAGE_STEPS=25
IMAGE_CFG=4.5
CHECKPOINT_MODEL=realvisxlV50_v50Bakedvae.safetensors

# Hires Fix (recommended for 8GB VRAM GPUs like RTX 5060)
# Generates at lower res then upscales for sharper detail
ENABLE_HIRES_FIX=true
HIRES_BASE_WIDTH=768
HIRES_BASE_HEIGHT=768
HIRES_UPSCALE_METHOD=nearest-exact
HIRES_DENOISE=0.45
HIRES_STEPS=15

# Refiner pass (extra detail on skin/face)
ENABLE_REFINER=true
REFINER_DENOISE=0.3
REFINER_STEPS=10

# App
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=info
